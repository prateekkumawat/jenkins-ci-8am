pipeline {
    agent {
        label 'agent1'
    }

    environment {
       KUBECONFIG = "${WORKSPACE}/kubeconfig"
    }

    stages{
        stage("Clean WorkSpaace") {
            steps{
              cleanWs()
            }
        }

        stage("AppCode Checkout"){
            steps {
                git branch:'kubernetes', url:'https://github.com/prateekkumawat/jenkins-ci-8am.git'
            }
        }
        
        stage("kubernetes-deployment"){
            steps{
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                sh """
                    cp $KUBECONFIG_FILE $KUBECONFIG
                    chmod 600 $KUBECONFIG
                    kubectl apply -f deploy/deployment.yaml --validate=false
                 """ 
                }   
            }
        }

        stage("Notification") {
            steps {
                script {
                    withCredentials([string(credentialsId: 'TEAMS_WEBHOOK', variable: 'WEBHOOK_URL')]) {
                        sh """
                        curl -H 'Content-Type: application/json' \
                        -d '{
                        "@type": "MessageCard",
                        "@context": "http://schema.org/extensions",
                        "summary": "Jenkins Build",
                        "themeColor": "00FF00",
                        "title": "Jenkins Job: ${env.JOB_NAME}",
                        "sections": [{
                            "facts": [
                                { "name": "🟢 **Status**", "value": "**SUCCESS ✅**" },
                                { "name": "🔢 **Build**", "value": "**#${env.BUILD_NUMBER}**" },
                                { "name": "🌿 **Branch / Tag**", "value": "**${env.GIT_BRANCH ?: params.GIT_REF}**" },
                                { "name": "🟢 **image**", "value": "**prateekkumawat/pythonapp:v0.0.1" },
                                { "name": "🔗 **Build URL**", "value": "[**Open Build**](${env.BUILD_URL})" }
                            ],
                            "text": "🚀 **Build completed successfully!**"
                        }]
                        }' \
                        \$WEBHOOK_URL
                        """
                    }
                }
            }
        }
   }
}    